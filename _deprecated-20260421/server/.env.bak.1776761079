# 飞书应用凭据（从飞书开放平台 https://open.feishu.cn 获取）
# 获取方式：见 SKILL.md「凭据配置速查」或 docs/onboarding.md
LARK_APP_ID=your_feishu_app_id
LARK_APP_SECRET=your_feishu_app_secret

# 接收卡片的用户 open_id
# 获取方式：见 SKILL.md「凭据配置速查」→「如何获取飞书 Open ID」
TARGET_OPEN_ID=your_target_open_id

# （可选）飞书群聊 chat_id，不设则通过 open_id 发私聊
# 获取方式：见 SKILL.md「凭据配置速查」→「如何获取飞书 Chat ID」
# CHAT_ID=

# Skill 根目录（安装路径）
SKILL_PATH=/path/to/nsksd-content-skill
PORT=9800

# 微信公众号凭据（从微信公众平台 https://mp.weixin.qq.com 获取）
# 获取方式：见 SKILL.md「凭据配置速查」或 docs/onboarding.md
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret
