# 飞书应用凭据（从飞书开放平台 https://open.feishu.cn 获取）
LARK_APP_ID=your_feishu_app_id
LARK_APP_SECRET=your_feishu_app_secret

# 接收卡片的用户 open_id（从飞书API获取，或在飞书管理后台查看）
TARGET_OPEN_ID=your_target_open_id

# Skill 根目录（安装路径）
SKILL_PATH=/path/to/nsksd-content-skill

# HTTP 管理端口
PORT=9800

# 微信公众号凭据（从微信公众平台 https://mp.weixin.qq.com 获取）
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret
